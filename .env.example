# =============================================
# SUPABASE CONFIGURATION
# =============================================
# Your Supabase project URL
VITE_SUPABASE_URL=your_supabase_url
# Optional: use a separate Supabase project for local development
VITE_SUPABASE_URL_DEV=your_supabase_url_dev
# Your Supabase anon/public key
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional: use a separate Supabase anon key for local development
VITE_SUPABASE_ANON_KEY_DEV=your-anon-key-dev
# Your Supabase service role key (for Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================
# STRIPE CONFIGURATION
# =============================================
# Your Stripe publishable key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
# Your Stripe secret key
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Webhook secret for Stripe events
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Success and cancel URLs for Stripe checkout
VITE_STRIPE_SUCCESS_URL=https://ats-friendly-resume-builder.vercel.app/#/subscription/success
VITE_STRIPE_CANCEL_URL=https://ats-friendly-resume-builder.vercel.app/#/pricing

# =============================================
# GROQ CONFIGURATION (CURRENT AI PROVIDER)
# =============================================
# Your Groq API key (server-side only)
# NOTE: In the future this may be replaced by OPENAI_API_KEY or GEMINI_API_KEY.
GROQ_API_KEY=your-groq-api-key
# Groq model to use (server-side)
GROQ_MODEL=llama-3.3-70b-versatile

# AI provider toggle (server-side and client-side)
# groq | gemini (future)
AI_PROVIDER=groq
VITE_AI_PROVIDER=groq

# =============================================
# GEMINI CONFIGURATION (FUTURE)
# =============================================
# Gemini API key (server-side)
GEMINI_API_KEY=your-gemini-api-key
# Gemini model to use (server-side)
GEMINI_MODEL=gemini-1.5-pro
# Optional: Vertex AI service account JSON (for Gemini via Vertex)
GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account", "...": "..."}

# =============================================
# OPENAI CONFIGURATION (FUTURE)
# =============================================
# Your OpenAI API key (future provider option)
VITE_OPENAI_API_KEY=sk-your-openai-api-key
# OpenAI model to use (future provider option)
VITE_OPENAI_MODEL=gpt-4o
# Maximum tokens to generate (future provider option)
VITE_OPENAI_MAX_TOKENS=4000

# =============================================
# APPLICATION CONFIGURATION
# =============================================
# Production mode
NODE_ENV=production
# Application URL
VITE_APP_URL=https://ats-friendly-resume-builder.vercel.app
# Feature flags
VITE_FEATURE_ENHANCED_AI=true
VITE_FEATURE_PREMIUM_TEMPLATES=true
# Maximum number of free resumes
VITE_MAX_FREE_RESUMES=3
