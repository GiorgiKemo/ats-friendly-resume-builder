# Ignore development files
node_modules
.git
.github
.vscode

# Ignore deployment scripts
deploy-edge-functions.sh
deploy-to-vercel.sh

# Ignore environment files except .env.production
.env
.env.local
.env.development
.env.functions

# Ignore Supabase local development files
supabase/.temp
supabase/.branches

# Ignore documentation files
*.md
!README.md

# Ignore test files
**/*.test.js
**/*.spec.js
**/__tests__

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
